FLAVOR=dev
API_BASE_URL=http://localhost:3000/api/v1
# Your computer's LAN IP — required for physical phones/tablets on the same Wi‑Fi
# Find it: macOS → System Settings → Network, or run: ipconfig getifaddr en0
API_DEVICE_HOST=192.168.1.100
API_CONNECTION_TIMEOUT=30000
API_RECEIVE_TIMEOUT=30000
# true = offline mock data | false = live Supabase backend + realtime
USE_MOCK_AUTH=false
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key
