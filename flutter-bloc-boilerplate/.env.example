FLAVOR=prod
# Production (Vercel)
API_BASE_URL=https://handyman-app.vercel.app/api/v1
# Local dev only — uncomment and set your LAN IP for physical device testing:
# API_BASE_URL=http://localhost:3000/api/v1
# API_DEVICE_HOST=192.168.1.100
API_CONNECTION_TIMEOUT=30000
API_RECEIVE_TIMEOUT=30000
# true = offline mock data | false = live Supabase backend + realtime
USE_MOCK_AUTH=false
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Firebase: run `flutterfire configure` — see FIREBASE_SETUP.md (no .env keys needed)
